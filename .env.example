# BharatBhraman environment configuration.
# Copy to `.env` and fill in real values. Never commit the filled-in .env.

# --- Required ---
# MongoDB connection string (Atlas or self-hosted).
MONGO_DB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>

# MongoDB database name (default: BharatBhraman_v2).
MONGO_DB_NAME=BharatBhraman_v2

# Flask session signing key. Use a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Google Gemini API key (GEMINI_API_KEY preferred; GEMINI_PRO also accepted).
GEMINI_API_KEY=your-gemini-api-key

# Geoapify API key, used for geocoding and hotel location lookups.
LOCATION=your-geoapify-api-key

# --- Optional (sensible defaults if unset) ---
# Gemini model name (default: gemini-flash-lite-latest).
GEMINI_MODEL=gemini-flash-lite-latest

# Guide platform fee as a fraction (default: 0.25).
PLATFORM_FEE=0.25

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO).
LOG_LEVEL=INFO

# Session lifetime in seconds (default: 1800 = 30 min).
SESSION_LIFETIME_SECONDS=1800

# Send the session cookie only over HTTPS. Set true in production (default:
# false so local http:// dev login works).
SESSION_COOKIE_SECURE=false

# Port for the local dev server `python run.py` (default: 5000).
PORT=5000

# Relax MongoDB TLS verification for local dev only (default: false).
MONGO_TLS_INSECURE=false

# Enable Flask debug/auto-reload for local dev only. Never enable in production
# (default: false).
FLASK_DEBUG=true
